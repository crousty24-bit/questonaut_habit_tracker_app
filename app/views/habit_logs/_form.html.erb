<%= form_with(model: habit_log) do |form| %>
  <% if habit_log.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(habit_log.errors.count, "error") %> prohibited this habit_log from being saved:</h2>

      <ul>
        <% habit_log.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :date, style: "display: block" %>
    <%= form.date_field :date %>
  </div>

  <div>
    <%= form.label :completed, style: "display: block" %>
    <%= form.checkbox :completed %>
  </div>

  <div>
    <%= form.label :habit_id, style: "display: block" %>
    <%= form.text_field :habit_id %>
  </div>

  <div>
    <%= form.submit %>
  </div>
<% end %>
