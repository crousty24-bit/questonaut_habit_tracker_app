<nav class="top-nav">
  <div class="nav-inner">

    <%# Brand %>
    <a href="<%= root_path %>" class="brand">
      <div class="brand-icon">🚀</div>
      <span class="brand-text">Questonaut</span>
    </a>

    <%# Nav links %>
    <% if user_signed_in? %>
      <div class="nav-links">
        <a href="<%= dashboard_path %>"
          class="nav-item <%= 'active' if current_page?(dashboard_path) %>">
          Dashboard
        </a>
        <a href="<%= habits_path %>"
          class="nav-item <%= 'active' if current_page?(habits_path) %>">
          Habits
        </a>
        <a href="<%= statistics_path %>"
          class="nav-item <%= 'active' if current_page?(statistics_path) %>">
          Statistics
        </a>
      </div>
    <% end %>

    <%# Right side : guest ou user %>
    <div class="nav-actions">
      <% if user_signed_in? %>
        <div class="hidden sm:block text-right">
          <div class="text-sm font-semibold text-white"><%= current_user.name.presence || current_user.email %></div>
          <div class="text-xs" style="color: var(--neon-cyan);">Level <%= current_user.level || 1 %></div>
        </div>
        <div class="w-10 h-10 rounded-full bg-gradient-to-br from-purple-500 to-pink-500
                    flex items-center justify-center text-xl border-2 border-cyan-500/30">
          👨‍🚀
        </div>
        <%= button_to "Logout", destroy_user_session_path,
            method: :delete,
            class: "btn btn-ghost btn-md" %>
      <% else %>
        <a href="<%= new_user_session_path %>" class="btn btn-primary btn-md">
          Start Mission
        </a>
      <% end %>
    </div>

  </div>
</nav>
