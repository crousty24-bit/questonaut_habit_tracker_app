<section class="auth-wrapper">
  <div class="auth-shell">
    <div class="auth-hero glass-panel">
      <div class="auth-hero__eyebrow">New Mission Available</div>
      <h1 class="auth-hero__title brand-font">
        Become the
        <span class="text-gradient">Commander</span>
        of your habits
      </h1>
      <p class="auth-hero__copy">
        Create your account to turn daily discipline into a space adventure with XP, streaks, and badges.
      </p>

      <div class="auth-hero__stats">
        <div class="auth-stat">
          <strong>Badges</strong>
          <span>unlock milestones</span>
        </div>
        <div class="auth-stat">
          <strong>Streaks</strong>
          <span>build momentum daily</span>
        </div>
        <div class="auth-stat">
          <strong>Levels</strong>
          <span>grow with every habit</span>
        </div>
      </div>
    </div>

    <div class="auth-card glass-panel neon-glow">
      <div class="auth-header">
        <span class="auth-header__icon">🛰️</span>
        <div class="auth-header__eyebrow">Create Your Account</div>
        <h2 class="auth-header__title">Sign Up</h2>
        <p class="auth-header__subtitle">Start your first mission and build a routine that lasts.</p>
      </div>

      <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "auth-form" }) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>

        <div class="form-group">
          <%= f.label :name, class: "form-label" do %>
            Commander Name <span class="required">*</span>
          <% end %>
          <%= f.text_field :name, autofocus: true, autocomplete: "name", placeholder: "Captain Nova", class: "input" %>
        </div>

        <div class="form-group">
          <%= f.label :email, class: "form-label" %>
          <%= f.email_field :email, autocomplete: "email", placeholder: "commander@questonaut.space", class: "input" %>
        </div>

        <div class="form-group">
          <%= f.label :password, class: "form-label" do %>
            Password <span class="required">*</span>
          <% end %>
          <%= f.password_field :password, autocomplete: "new-password", placeholder: "Create a secure password", class: "input" %>
          <% if @minimum_password_length %>
            <div class="form-hint"><%= @minimum_password_length %> characters minimum.</div>
          <% end %>
        </div>

        <div class="form-group">
          <%= f.label :password_confirmation, class: "form-label" do %>
            Confirm Password <span class="required">*</span>
          <% end %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password", placeholder: "Repeat your password", class: "input" %>
        </div>

        <%= f.submit "Start Mission", class: "btn btn-primary btn-lg auth-submit" %>
      <% end %>

      <%= render "devise/shared/links" %>
    </div>
  </div>
</section>
