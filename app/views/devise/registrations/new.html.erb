<% signup_feedback = validation_feedback_data(resource) %>

<section class="auth-wrapper">
  <div class="auth-shell">
    <div class="auth-hero glass-panel">
      <div class="auth-hero__eyebrow">New Mission Available</div>
      <h1 class="auth-hero__title brand-font">
        Become the
        <span class="text-gradient">Commander</span>
        of your habits
      </h1>
      <p class="auth-hero__copy">
        Create your account to turn daily discipline into a space adventure with XP, streaks, and badges.
      </p>

      <div class="auth-hero__stats">
        <div class="auth-stat">
          <strong>Badges</strong>
          <span>unlock milestones</span>
        </div>
        <div class="auth-stat">
          <strong>Streaks</strong>
          <span>build momentum daily</span>
        </div>
        <div class="auth-stat">
          <strong>Levels</strong>
          <span>grow with every habit</span>
        </div>
      </div>
    </div>

    <div class="auth-card glass-panel neon-glow">
      <div class="auth-header">
        <span class="auth-header__icon">🛰️</span>
        <div class="auth-header__eyebrow">Create Your Account</div>
        <h2 class="auth-header__title">Sign Up</h2>
        <p class="auth-header__subtitle">Start your first mission and build a routine that lasts.</p>
      </div>

      <%= form_for(resource,
                   as: resource_name,
                   url: registration_path(resource_name),
                   html: { class: "auth-form", data: signup_feedback }) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>
        <%= render "shared/validation_toast", message: signup_feedback[:validation_feedback_notification_message_value] %>

        <div class="form-group">
          <%= f.label :name, class: "form-label" do %>
            Commander Name <span class="required">*</span>
          <% end %>
          <%= f.text_field :name,
                           autofocus: true,
                           autocomplete: "name",
                           placeholder: "Captain Nova",
                           class: validation_field_classes(resource, :name, "input"),
                           data: validation_field_data(:name) %>
        </div>

        <div class="form-group">
          <%= f.label :email, class: "form-label" %>
          <%= f.email_field :email,
                            autocomplete: "email",
                            placeholder: "commander@questonaut.space",
                            class: validation_field_classes(resource, :email, "input"),
                            data: validation_field_data(:email) %>
        </div>

        <div class="form-group">
          <%= f.label :password, class: "form-label" do %>
            Password <span class="required">*</span>
          <% end %>
          <%= f.password_field :password,
                               autocomplete: "new-password",
                               placeholder: "Create a secure password",
                               class: validation_field_classes(resource, :password, "input"),
                               data: validation_field_data(:password) %>
          <% if @minimum_password_length %>
            <div class="form-hint"><%= @minimum_password_length %> characters minimum.</div>
          <% end %>
        </div>

        <div class="form-group">
          <%= f.label :password_confirmation, class: "form-label" do %>
            Confirm Password <span class="required">*</span>
          <% end %>
          <%= f.password_field :password_confirmation,
                               autocomplete: "new-password",
                               placeholder: "Repeat your password",
                               class: validation_field_classes(resource, :password_confirmation, "input"),
                               data: validation_field_data(:password_confirmation) %>
        </div>

        <div class="form-group">
          <label class="form-label">
            <%= f.check_box :terms_accepted, class: "mr-2" %>
            I accept the <%= link_to "Terms of Use (CGU)", terms_path, target: "_blank", rel: "noopener" %>.
            <span class="required">*</span>
          </label>
        </div>

        <%= f.submit "Start Mission", class: "btn btn-primary btn-lg auth-submit" %>
      <% end %>

      <%= render "devise/shared/links" %>
    </div>
  </div>
</section>
