<%= turbo_frame_tag "statistics_badge_collection" do %>
  <div class="glass-panel statistics-badges">
    <h2 class="statistics-badges__title">
      <span>🏆</span>
      <span>Badge Collection</span>
      <span class="statistics-badges__count">(<%= @unlocked_badges_count %>/<%= @badges.count %> Unlocked)</span>
    </h2>

    <% @badge_groups.each do |group_name, badges| %>
      <% next if badges.empty? %>
      <section class="statistics-badge-group">
        <h3 class="statistics-badge-group__title"><%= group_name %></h3>
        <div class="badge-grid">
          <% badges.each do |badge| %>
            <% unlocked = @user_badge_ids.include?(badge.id) %>
            <% badge_name = badge.collection_group == :category ? badge.name.delete_prefix("Tag: ").strip : badge.display_name %>
            <% badge_subtitle = badge.collection_subtitle if unlocked %>
            <% badge_subtitle = nil if badge_subtitle == badge_name %>
            <div class="badge-item badge-item--collection <%= 'locked' unless unlocked %>">
              <div class="badge-asset badge-asset--md">
                <% if badge.image_path.present? %>
                  <%= image_tag badge_image(badge, unlocked: unlocked),
                                class: "pixel-badge #{'is-locked' unless unlocked}",
                                alt: badge.display_name,
                                width: 72,
                                height: 72,
                                loading: "lazy",
                                decoding: "async" %>
                <% else %>
                  <div class="statistics-badge-fallback <%= 'locked' unless unlocked %>"><%= badge.display_name.first.upcase %></div>
                <% end %>
              </div>
              <div class="badge-name"><%= badge_name %></div>
              <% if badge_subtitle.present? %>
                <div class="badge-desc"><%= badge_subtitle %></div>
              <% end %>
            </div>
          <% end %>
        </div>
      </section>
    <% end %>
  </div>
<% end %>
