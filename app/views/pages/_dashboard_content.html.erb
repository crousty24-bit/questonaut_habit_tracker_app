<%
  total_xp = current_user.total_xp || 0
  level = current_user.level || 1
  next_level_xp = [level * 100, 100].max
  progress_percent = [[current_user.xp_progress_percentage, 0].max, 100].min
  cockpit_habits = @dashboard_habits || @habits
  active_habits = cockpit_habits.count
  daily_habits = cockpit_habits.select { |habit| habit.frequency == "daily" }
  weekly_habits = cockpit_habits.select { |habit| habit.frequency == "weekly" }
  completed_today = @dashboard_completed_today || cockpit_habits.count { |habit| habit.completed_on?(@today) }
  weekly_completed = @dashboard_weekly_completed || @weekly_completed_logs.count
  weekly_completion_rate = @dashboard_weekly_completion_rate || (active_habits.positive? ? [(weekly_completed.to_f / (active_habits * 7) * 100).round, 100].min : 0)
  xp_this_week = weekly_completed * 10
  active_category = @current_category.presence || "all"
  dashboard_base_path = dashboard_path({ category: @current_category.presence }.compact)
  daily_timer_deadline = habit_timer_deadline(now: @now)
  daily_timer_seconds_remaining = habit_timer_seconds_remaining(now: @now)
  weekly_timer_deadline = habit_timer_deadline(period: :weekly, now: @now)
  weekly_timer_seconds_remaining = habit_timer_seconds_remaining(period: :weekly, now: @now)
  avatar_options = User::AVATAR_OPTIONS.map do |id, config|
    { id: id, name: config[:name], asset: asset_path(config[:asset]) }
  end
  current_avatar = avatar_options.find { |avatar| avatar[:id] == current_user.avatar_key } || avatar_options.first
  featured_quests = @cockpit_featured_quests || []
  cockpit_badges = @cockpit_badges || []
  unlocked_badges = @cockpit_unlocked_badges_count || cockpit_badges.count { |badge| badge[:unlocked] }
  core_temperature = @dashboard_core_temperature || [[18 + (active_habits - completed_today) * 16, 96].min, 14].max
  oxygen_reserve = @dashboard_oxygen_reserve || (active_habits.positive? ? [[(completed_today.to_f / active_habits * 100).round, 100].min, 22].max : 22)

  best_streak = @dashboard_best_streak || cockpit_habits.map { |habit| habit.current_streak(as_of: @today) }.max || 0
  login_streak = @dashboard_login_streak || current_user.login_streak || 0
  new_habit = @new_habit || current_user.habits.new(category_name: "health")
  editing_habit = @editing_habit || current_user.habits.new
  deleting_habit = @deleting_habit
  editing_category = if editing_habit.respond_to?(:category_name) && editing_habit.category_name.present?
                       editing_habit.category_name
                     elsif editing_habit.respond_to?(:primary_category) && editing_habit.persisted?
                       editing_habit.primary_category
                     else
                       "health"
                     end
%>

<div class="stars-bg" data-controller="stars"></div>

<section class="page-wrapper dashboard-page" data-controller="dashboard">
  <div class="glass-panel neon-glow dashboard-hero dashboard-hero--cockpit"
       data-controller="cockpit-dashboard"
       data-action="mousemove->cockpit-dashboard#parallax mouseleave->cockpit-dashboard#reset">
    <div class="dashboard-hero__halo dashboard-hero__halo--cyan"></div>
    <div class="dashboard-hero__halo dashboard-hero__halo--purple"></div>
    <div class="dashboard-cockpit__vignette" aria-hidden="true"></div>
    <div class="dashboard-cockpit__scanlines" aria-hidden="true"></div>
    <div class="dashboard-cockpit__viewport" aria-hidden="true">
      <div class="dashboard-cockpit__starfield"></div>
      <div class="dashboard-cockpit__planet"></div>
      <div class="dashboard-cockpit__horizon"></div>
    </div>
    <div class="dashboard-cockpit__pilot">
      <img id="current-avatar"
           class="dashboard-cockpit__pilot-image"
           src="<%= current_avatar[:asset] %>"
           alt="<%= current_avatar[:name] %>">
      <div class="dashboard-cockpit__pilot-meta">
        <strong id="current-avatar-name"><%= current_avatar[:name] %></strong>
        <span><%= current_user.name.presence || current_user.email %></span>
      </div>
    </div>
    <div class="dashboard-cockpit__frame dashboard-cockpit__frame--left" aria-hidden="true"></div>
    <div class="dashboard-cockpit__frame dashboard-cockpit__frame--right" aria-hidden="true"></div>
    <div class="dashboard-cockpit__frame dashboard-cockpit__frame--bottom" aria-hidden="true"></div>

    <div class="dashboard-cockpit">
      <header class="dashboard-cockpit__header">
        <div>
          <div class="dashboard-hero__eyebrow">Command Bridge</div>
          <h1 class="dashboard-title dashboard-title--cockpit">Welcome Back Commander</h1>
          <p class="dashboard-subtitle dashboard-subtitle--cockpit">
            Day <%= [login_streak, 1].max %> of your exploration mission
          </p>
          <div class="dashboard-streaks dashboard-streaks--cockpit">
            <div class="dashboard-streak-chip dashboard-streak-chip--orange">
              <span class="dashboard-streak-chip__icon">🔥</span>
              <span class="dashboard-streak-chip__label">Login streak</span>
              <strong><%= login_streak %> days</strong>
            </div>
            <div class="dashboard-streak-chip dashboard-streak-chip--cyan">
              <span class="dashboard-streak-chip__icon">⚡</span>
              <span class="dashboard-streak-chip__label">Best streak</span>
              <strong><%= best_streak %> days</strong>
            </div>
          </div>
        </div>

        <button type="button" class="btn btn-primary btn-md dashboard-cta dashboard-cta--cockpit" data-action="dashboard#openCreateModal">
          <span>+</span>
          <span>New Mission</span>
        </button>
      </header>

      <div class="dashboard-cockpit__grid">
        <aside class="cockpit-widget cockpit-widget--streak">
          <div class="cockpit-widget__header">
            <span class="cockpit-widget__label">Streak Control</span>
            <strong class="cockpit-widget__headline">Daily Activation</strong>
          </div>

          <div class="cockpit-throttle">
            <div class="cockpit-throttle__track">
              <% 20.times do |segment| %>
                <% filled_segments = [[login_streak, 20].min, 0].max %>
                <% active_segment = segment >= 20 - filled_segments %>
                <span class="cockpit-throttle__segment <%= 'is-active' if active_segment %>"></span>
              <% end %>
            </div>
          </div>

          <div class="cockpit-streak-display">
            <span class="cockpit-streak-display__value"><%= login_streak %></span>
            <span class="cockpit-streak-display__label">JOURS ACTIVÉS</span>
          </div>
        </aside>

        <section class="cockpit-widget cockpit-widget--terminal">
          <div class="cockpit-terminal__header">
            <div>
              <span class="cockpit-widget__label">Mission Terminal</span>
              <strong class="cockpit-widget__headline">Quest Logs</strong>
            </div>
            <span class="cockpit-terminal__status">ONLINE</span>
          </div>

          <div class="cockpit-terminal__list">
            <% if featured_quests.any? %>
              <% featured_quests.each do |quest| %>
                <article class="cockpit-quest-card" style="--quest-accent: <%= quest[:accent] %>;">
                  <div class="cockpit-quest-card__meta">
                    <div>
                      <h3 class="cockpit-quest-card__title"><%= quest[:title] %></h3>
                      <p class="cockpit-quest-card__type"><%= quest[:type] %></p>
                    </div>
                    <span class="cockpit-quest-card__xp">+<%= quest[:xp_reward] %> XP</span>
                  </div>

                  <div class="cockpit-quest-card__progress">
                    <div class="cockpit-quest-card__bar">
                      <span style="width: <%= quest[:progress_value] %>%"></span>
                    </div>
                    <strong><%= quest[:progress_value] %>%</strong>
                  </div>

                  <div class="cockpit-quest-card__actions">
                    <button type="button" class="cockpit-btn cockpit-btn--primary" data-action="dashboard#openCreateModal">POURSUIVRE</button>
                    <button type="button" class="cockpit-btn cockpit-btn--secondary">DÉTAILS</button>
                  </div>
                </article>
              <% end %>
            <% else %>
              <article class="cockpit-quest-card cockpit-quest-card--empty">
                <div class="cockpit-quest-card__meta">
                  <div>
                    <h3 class="cockpit-quest-card__title">Aucune mission active</h3>
                    <p class="cockpit-quest-card__type">Terminal en attente</p>
                  </div>
                </div>
                <div class="cockpit-quest-card__actions">
                  <button type="button" class="cockpit-btn cockpit-btn--primary" data-action="dashboard#openCreateModal">LANCER UNE MISSION</button>
                </div>
              </article>
            <% end %>
          </div>
        </section>

        <aside class="cockpit-widget cockpit-widget--badges">
          <div class="cockpit-widget__header">
            <span class="cockpit-widget__label">Badge Matrix</span>
            <strong class="cockpit-widget__headline"><%= unlocked_badges %> / 6 unlocked</strong>
          </div>

          <div class="cockpit-badge-grid">
            <% cockpit_badges.each do |badge| %>
              <% unlocked = badge[:unlocked] %>
              <article class="cockpit-badge <%= "cockpit-badge--#{badge[:color]}" if unlocked %> <%= 'is-unlocked' if unlocked %>">
                <div class="cockpit-badge__hex">
                  <% if badge[:badge].image_path.present? %>
                    <%= image_tag badge_image(badge[:badge], unlocked: unlocked),
                                  class: "cockpit-badge__asset #{'is-locked' unless unlocked}",
                                  alt: badge[:badge].display_name,
                                  loading: "lazy",
                                  decoding: "async" %>
                  <% else %>
                    <span class="cockpit-badge__icon"><%= badge[:name].first.upcase %></span>
                  <% end %>
                </div>
                <strong class="cockpit-badge__name"><%= badge[:name] %></strong>
                <% if unlocked %>
                  <span class="cockpit-badge__state"><%= badge[:subtitle].presence || "Unlocked" %></span>
                <% else %>
                  <div class="cockpit-badge__lock-progress">
                    <span style="width: <%= badge[:progress_percent] %>%"></span>
                  </div>
                <% end %>
              </article>
            <% end %>
          </div>
        </aside>
      </div>

      <div class="dashboard-cockpit__pilot-row">
        <article class="cockpit-widget cockpit-widget--xp">
          <div class="cockpit-widget__header">
            <span class="cockpit-widget__label">Propulsion Charge</span>
            <strong class="cockpit-widget__headline">XP Capacity</strong>
          </div>

          <div class="xp-panel xp-panel--hero xp-panel--cockpit">
            <div class="xp-panel__bar-stack" style="--xp-progress: <%= progress_percent %>%;">
              <div class="xp-panel__flight-layer" aria-hidden="true">
                <div class="xp-panel__rocket-track">
                  <span class="xp-bar__rocket">🚀</span>
                </div>
              </div>
              <div class="xp-bar xp-bar--dashboard">
                <div class="xp-fill" style="width: <%= progress_percent %>%"></div>
              </div>
            </div>
          </div>

          <div class="cockpit-xp-meta">
            <span>Level <%= level %></span>
            <span><%= progress_percent %>% charge</span>
          </div>
        </article>

        <div class="dashboard-cockpit__gauges">
          <article class="cockpit-gauge cockpit-gauge--streak">
            <span class="cockpit-gauge__label">Login Streak</span>
            <strong class="cockpit-gauge__value"><%= login_streak %> d</strong>
            <div class="cockpit-gauge__bar"><span style="width: <%= [[login_streak * 5, 100].min, 8].max %>%"></span></div>
          </article>
          <article class="cockpit-gauge cockpit-gauge--best-streak">
            <span class="cockpit-gauge__label">Best Streak</span>
            <strong class="cockpit-gauge__value"><%= best_streak %> d</strong>
            <div class="cockpit-gauge__bar"><span style="width: <%= [[best_streak * 5, 100].min, 8].max %>%"></span></div>
          </article>
          <article class="cockpit-gauge cockpit-gauge--temperature">
            <span class="cockpit-gauge__label">Température Noyau</span>
            <strong class="cockpit-gauge__value"><%= core_temperature %>%</strong>
            <div class="cockpit-gauge__bar"><span style="width: <%= core_temperature %>%"></span></div>
          </article>
          <article class="cockpit-gauge cockpit-gauge--oxygen">
            <span class="cockpit-gauge__label">Réserves Oxygène</span>
            <strong class="cockpit-gauge__value"><%= oxygen_reserve %>%</strong>
            <div class="cockpit-gauge__bar"><span style="width: <%= oxygen_reserve %>%"></span></div>
          </article>
        </div>
      </div>
    </div>
  </div>

  <div class="dashboard-grid">
    <div class="dashboard-main">
      <% if @streak_reset_habits.any? %>
        <div class="dashboard-alert dashboard-alert--warning">
          <div class="dashboard-alert__icon">⚠️</div>
          <div class="dashboard-alert__content">
            <h3 class="dashboard-alert__title">
              <%= pluralize(@streak_reset_habits.count, "mission") %> missed the last 24 hours
            </h3>
            <p class="dashboard-alert__message">
              The streak <%= @streak_reset_habits.one? ? "for this mission has" : "for these missions has" %> been reset to 0 because it was not validated yesterday.
            </p>
            <ul class="dashboard-alert__list">
              <% @streak_reset_habits.each do |habit| %>
                <li><strong><%= habit.title %></strong> reset from <%= habit.streak_before_reset(as_of: @today) %> to 0.</li>
              <% end %>
            </ul>
          </div>
        </div>
      <% end %>

      <div class="missions-header">
        <div>
          <h2 class="dashboard-section-title">Missions</h2>
          <p class="dashboard-section-subtitle">
            <span class="dashboard-accent"><%= completed_today %>/<%= active_habits %> completed</span>
            today
          </p>
        </div>
        <div class="dashboard-date"><%= @today.strftime("%A, %B %-d, %Y") %></div>
      </div>

      <div class="filter-bar dashboard-filter-bar">
        <%= link_to "All", dashboard_path, class: "filter-btn #{'active' if active_category == 'all'}", data: { dashboard_target: "filterButton", dashboard_filter: "all", action: "dashboard#filter" } %>
        <%= link_to "Health", dashboard_path(category: "health"), class: "filter-btn #{'active' if active_category == 'health'}", data: { dashboard_target: "filterButton", dashboard_filter: "health", action: "dashboard#filter" } %>
        <%= link_to "Productivity", dashboard_path(category: "productivity"), class: "filter-btn #{'active' if active_category == 'productivity'}", data: { dashboard_target: "filterButton", dashboard_filter: "productivity", action: "dashboard#filter" } %>
        <%= link_to "Learning", dashboard_path(category: "learning"), class: "filter-btn #{'active' if active_category == 'learning'}", data: { dashboard_target: "filterButton", dashboard_filter: "learning", action: "dashboard#filter" } %>
        <%= link_to "Fitness", dashboard_path(category: "fitness"), class: "filter-btn #{'active' if active_category == 'fitness'}", data: { dashboard_target: "filterButton", dashboard_filter: "fitness", action: "dashboard#filter" } %>
        <%= link_to "Nutrition", dashboard_path(category: "nutrition"), class: "filter-btn #{'active' if active_category == 'nutrition'}", data: { dashboard_target: "filterButton", dashboard_filter: "nutrition", action: "dashboard#filter" } %>
      </div>

      <div class="missions-list">
        <% if @habits.any? %>
          <% [["Daily Missions", daily_habits], ["Weekly Missions", weekly_habits]].each do |section_title, habits| %>
            <% next if habits.empty? %>
            <section class="dashboard-section-block" data-dashboard-target="section">
              <div class="missions-section-header">
                <div class="missions-section-label"><%= section_title %></div>
                <% if section_title == "Daily Missions" %>
                  <div class="habit-timer habit-timer--daily missions-section-timer"
                       data-controller="habit-timer"
                       data-habit-timer-expiry-value="<%= daily_timer_deadline.iso8601 %>">
                    <span class="habit-timer__label" data-habit-timer-target="label">available in</span>
                    <strong class="habit-timer__value" data-habit-timer-target="value"><%= format_habit_timer(daily_timer_seconds_remaining) %></strong>
                  </div>
                <% elsif section_title == "Weekly Missions" %>
                  <div class="habit-timer habit-timer--weekly missions-section-timer"
                       data-controller="habit-timer"
                       data-habit-timer-expiry-value="<%= weekly_timer_deadline.iso8601 %>">
                    <span class="habit-timer__label" data-habit-timer-target="label">available in</span>
                    <strong class="habit-timer__value" data-habit-timer-target="value"><%= format_habit_timer(weekly_timer_seconds_remaining) %></strong>
                  </div>
                <% end %>
              </div>

              <% habits.each do |habit| %>
                <% category = habit.primary_category %>
                <% completed = habit.completed_on?(@today) %>
                <% streak = habit.current_streak(as_of: @today) %>

                <article class="habit-card <%= 'completed' if completed %>" data-dashboard-target="card" data-category="<%= category %>">
                  <div class="dashboard-habit">
                    <div class="dashboard-habit__main">
                      <div class="cat-icon <%= category %>"><%= category_icon_for(category) %></div>

                      <div class="dashboard-habit__content">
                        <div class="dashboard-habit__topline">
                          <h3 class="dashboard-habit__title <%= 'is-complete' if completed %>"><%= habit.title %></h3>
                          <span class="category-tag cat-<%= category %>"><%= category %></span>
                        </div>

                        <p class="dashboard-habit__description">
                          <%= habit.description.presence || "Stay consistent and complete this mission to earn XP." %>
                        </p>

                        <div class="dashboard-habit__meta">
                          <span class="streak-flame">🔥 <%= streak %> day<%= "s" if streak != 1 %></span>
                          <span class="dashboard-habit__xp">+10 XP</span>
                        </div>
                      </div>
                    </div>

                    <div class="dashboard-habit__action">
                      <div class="dashboard-habit__controls">
                        <button type="button"
                                class="habit-action-btn"
                                title="Edit"
                                data-action="dashboard#openEditModal"
                                data-habit-id="<%= habit.id %>"
                                data-habit-path="<%= habit_path(habit) %>"
                                data-habit-title="<%= habit.title %>"
                                data-habit-description="<%= habit.description.to_s %>"
                                data-habit-frequency="<%= habit.frequency %>"
                                data-habit-category="<%= category %>">✏️</button>
                        <%= link_to dashboard_path({ category: @current_category.presence, delete_mission_id: habit.id }.compact),
                                    class: "habit-action-btn delete",
                                    title: "Delete",
                                    data: { action: "dashboard#openDeleteModal", habit_delete_path: habit_path(habit), habit_title: habit.title } do %>
                          &times;
                        <% end %>
                      </div>

                      <% if completed %>
                        <button class="mission-success-btn active" disabled>✓ Completed</button>
                      <% else %>
                        <%= button_to "🚀 Mission Success",
                                      habit_habit_logs_path(habit),
                                      method: :post,
                                      params: { habit_log: { date: @today, completed: true, habit_id: habit.id } },
                                      class: "mission-success-btn" %>
                      <% end %>
                    </div>
                  </div>
                </article>
              <% end %>
            </section>
          <% end %>
        <% else %>
          <div class="glass-panel dashboard-empty">
            <h3 class="dashboard-empty__title">No missions yet</h3>
            <p class="dashboard-empty__copy">
              Create your first habit to start earning XP, building streaks, and unlocking badges.
            </p>
            <button type="button" class="btn btn-primary btn-md" data-action="dashboard#openCreateModal">Create First Mission</button>
          </div>
        <% end %>
      </div>
    </div>

    <aside class="sidebar">
      <div class="glass-panel streak-card">
        <div class="streak-card__glow"></div>
        <div class="streak-flame dashboard-sidebar-icon">🔥</div>
        <div class="streak-card__days"><%= login_streak %> Day<%= "s" if login_streak != 1 %></div>
        <div class="streak-card__label">Current Login Streak</div>
        <div class="streak-card__best">Best mission streak: <%= best_streak %> day<%= "s" if best_streak != 1 %></div>
      </div>

      <div class="glass-panel dashboard-widget">
        <h3 class="dashboard-widget__title">🏅 Recent Badges</h3>
        <div class="dashboard-badges">
          <% if @recent_badges.any? %>
            <% @recent_badges.each do |badge| %>
              <div class="badge-item badge-item--recent">
                <div class="badge-asset badge-asset--sm">
                  <% if badge.image_path.present? %>
                    <%= image_tag badge_image(badge),
                                  class: "pixel-badge",
                                  alt: badge.display_name,
                                  width: 56,
                                  height: 56,
                                  loading: "lazy",
                                  decoding: "async" %>
                  <% else %>
                    <div class="dashboard-badge-fallback"><%= badge.display_name.first.upcase %></div>
                  <% end %>
                </div>
                <div class="badge-name"><%= badge.display_name %></div>
              </div>
            <% end %>
          <% else %>
            <p class="dashboard-widget__empty">Your first badges will appear here.</p>
          <% end %>
        </div>
        <%= link_to "View all badges →", statistics_path, class: "dashboard-widget__link", data: { turbo_frame: "_top" } %>
      </div>

      <div class="glass-panel dashboard-widget">
        <h3 class="dashboard-widget__title">📊 This Week</h3>
        <div class="dashboard-stats">
          <div class="dashboard-stat-row">
            <span>Completion Rate</span>
            <strong><%= weekly_completion_rate %>%</strong>
          </div>
          <div class="xp-bar thin">
            <div class="xp-fill green" style="width: <%= weekly_completion_rate %>%"></div>
          </div>
          <div class="dashboard-stat-row">
            <span>Active Habits</span>
            <strong><%= active_habits %></strong>
          </div>
          <div class="dashboard-stat-row">
            <span>XP Earned</span>
            <strong class="dashboard-accent">+<%= xp_this_week %> XP</strong>
          </div>
        </div>
      </div>
    </aside>
  </div>

  <div id="createHabitModal"
       class="modal-overlay dashboard-mission-modal <%= 'active' if @show_create_habit_modal %>"
       data-dashboard-target="createModal"
       data-action="click->dashboard#maybeCloseCreateModal">
    <div class="modal-box">
      <div class="modal-header">
        <h3 class="modal-title">🚀 New Mission</h3>
        <button type="button" class="modal-close" data-action="dashboard#closeCreateModal">&times;</button>
      </div>

      <% create_habit_feedback = validation_feedback_data(new_habit) %>
      <%= form_with(model: new_habit, url: habits_path, class: "dashboard-modal-form", data: create_habit_feedback) do |form| %>
        <%= render "shared/model_errors", record: new_habit %>
        <%= render "shared/validation_toast", message: create_habit_feedback[:validation_feedback_notification_message_value] %>

        <div class="form-group">
          <%= form.label :title, "Mission Name", class: "form-label" %>
          <%= form.text_field :title,
                              class: validation_field_classes(new_habit, :title, "input"),
                              placeholder: "e.g., Morning Meditation",
                              required: true,
                              data: validation_field_data(:title) %>
        </div>

        <div class="form-group">
          <%= form.label :description, "Description", class: "form-label" %>
          <%= form.text_area :description,
                             rows: 3,
                             class: validation_field_classes(new_habit, :description, "textarea"),
                             placeholder: "Describe your goal...",
                             data: validation_field_data(:description) %>
        </div>

        <div class="form-group">
          <label class="form-label">Frequency</label>
          <div class="dashboard-modal-form__choices">
            <button type="button"
                    class="freq-option <%= (new_habit.frequency || 'daily') == 'daily' ? 'selected' : '' %>"
                    data-action="dashboard#selectCreateFrequency"
                    data-frequency-option
                    data-value="daily">
              <span class="freq-icon">📅</span>
              <span class="freq-title">Daily</span>
              <span class="freq-desc">Validate every day</span>
            </button>
            <button type="button"
                    class="freq-option <%= new_habit.frequency == 'weekly' ? 'selected' : '' %>"
                    data-action="dashboard#selectCreateFrequency"
                    data-frequency-option
                    data-value="weekly">
              <span class="freq-icon">📆</span>
              <span class="freq-title">Weekly</span>
              <span class="freq-desc">Once per week only</span>
            </button>
          </div>
          <%= form.hidden_field :frequency,
                                value: (new_habit.frequency || "daily"),
                                data: { dashboard_target: "createFrequencyInput" } %>
        </div>

        <div class="form-group">
          <label class="form-label">Category (select one)</label>
          <% selected_category = new_habit.category_name.presence || "health" %>
          <div class="dashboard-modal-form__tags">
            <button type="button" class="selectable-tag tag-health <%= 'selected' if selected_category == 'health' %>" data-action="dashboard#selectCreateCategory" data-category-option data-value="health">❤️ Health</button>
            <button type="button" class="selectable-tag tag-productivity <%= 'selected' if selected_category == 'productivity' %>" data-action="dashboard#selectCreateCategory" data-category-option data-value="productivity">⚡ Productivity</button>
            <button type="button" class="selectable-tag tag-learning <%= 'selected' if selected_category == 'learning' %>" data-action="dashboard#selectCreateCategory" data-category-option data-value="learning">📚 Learning</button>
            <button type="button" class="selectable-tag tag-fitness <%= 'selected' if selected_category == 'fitness' %>" data-action="dashboard#selectCreateCategory" data-category-option data-value="fitness">💪 Fitness</button>
            <button type="button" class="selectable-tag tag-nutrition <%= 'selected' if selected_category == 'nutrition' %>" data-action="dashboard#selectCreateCategory" data-category-option data-value="nutrition">🥗 Nutrition</button>
          </div>
          <%= form.hidden_field :category_name,
                                value: selected_category,
                                data: { dashboard_target: "createCategoryInput" } %>
        </div>

        <div class="dashboard-modal-form__actions">
          <button type="button" class="btn btn-ghost btn-md dashboard-modal-form__button" data-action="dashboard#closeCreateModal">Cancel</button>
          <%= form.submit "Create Mission", class: "btn btn-primary btn-md dashboard-modal-form__button" %>
        </div>
      <% end %>
    </div>
  </div>

  <div id="editHabitModal"
       class="modal-overlay dashboard-mission-modal <%= 'active' if @show_edit_habit_modal %>"
       data-dashboard-target="editModal"
       data-action="click->dashboard#maybeCloseEditModal">
    <div class="modal-box">
      <div class="modal-header">
        <h3 class="modal-title">✏️ Edit Mission</h3>
        <button type="button" class="modal-close" data-action="dashboard#closeEditModal">&times;</button>
      </div>

      <% edit_habit_feedback = validation_feedback_data(editing_habit) %>
      <%= form_with(scope: :habit,
                    url: (@editing_habit&.persisted? ? habit_path(@editing_habit) : "#"),
                    method: :post,
                    html: {
                      class: "dashboard-modal-form",
                      id: "editHabitForm",
                      data: edit_habit_feedback.merge(dashboard_target: "editForm")
                    }) do |form| %>
        <%= hidden_field_tag :_method, "patch", id: "editHabitMethod" %>

        <%= render "shared/model_errors", record: @editing_habit %>

        <%= render "shared/validation_toast", message: edit_habit_feedback[:validation_feedback_notification_message_value] %>

        <div class="form-group">
          <%= form.label :title, "Mission Name", class: "form-label" %>
          <%= form.text_field :title,
                              class: validation_field_classes(editing_habit, :title, "input"),
                              placeholder: "e.g., Morning Meditation",
                              required: true,
                              id: "editHabitTitle",
                              value: editing_habit.title,
                              data: validation_field_data(:title).merge(dashboard_target: "editTitle") %>
        </div>

        <div class="form-group">
          <%= form.label :description, "Description", class: "form-label" %>
          <%= form.text_area :description,
                             rows: 3,
                             class: validation_field_classes(editing_habit, :description, "textarea"),
                             placeholder: "Describe your goal...",
                             id: "editHabitDescription",
                             data: validation_field_data(:description).merge(dashboard_target: "editDescription") do %><%= editing_habit.description %><% end %>
        </div>

        <div class="form-group">
          <label class="form-label">Frequency</label>
          <div class="dashboard-modal-form__choices">
            <button type="button"
                    class="freq-option <%= (editing_habit.frequency || 'daily') == 'daily' ? 'selected' : '' %>"
                    data-action="dashboard#selectEditFrequency"
                    data-edit-frequency-option
                    data-value="daily">
              <span class="freq-icon">📅</span>
              <span class="freq-title">Daily</span>
              <span class="freq-desc">Validate every day</span>
            </button>
            <button type="button"
                    class="freq-option <%= editing_habit.frequency == 'weekly' ? 'selected' : '' %>"
                    data-action="dashboard#selectEditFrequency"
                    data-edit-frequency-option
                    data-value="weekly">
              <span class="freq-icon">📆</span>
              <span class="freq-title">Weekly</span>
              <span class="freq-desc">Once per week only</span>
            </button>
          </div>
          <%= form.hidden_field :frequency,
                                value: (editing_habit.frequency || "daily"),
                                id: "editHabitFrequency",
                                data: { dashboard_target: "editFrequencyInput" } %>
        </div>

        <div class="form-group">
          <label class="form-label">Category (select one)</label>
          <div class="dashboard-modal-form__tags">
            <button type="button" class="selectable-tag tag-health <%= 'selected' if editing_category == 'health' %>" data-action="dashboard#selectEditCategory" data-edit-category-option data-value="health">❤️ Health</button>
            <button type="button" class="selectable-tag tag-productivity <%= 'selected' if editing_category == 'productivity' %>" data-action="dashboard#selectEditCategory" data-edit-category-option data-value="productivity">⚡ Productivity</button>
            <button type="button" class="selectable-tag tag-learning <%= 'selected' if editing_category == 'learning' %>" data-action="dashboard#selectEditCategory" data-edit-category-option data-value="learning">📚 Learning</button>
            <button type="button" class="selectable-tag tag-fitness <%= 'selected' if editing_category == 'fitness' %>" data-action="dashboard#selectEditCategory" data-edit-category-option data-value="fitness">💪 Fitness</button>
            <button type="button" class="selectable-tag tag-nutrition <%= 'selected' if editing_category == 'nutrition' %>" data-action="dashboard#selectEditCategory" data-edit-category-option data-value="nutrition">🥗 Nutrition</button>
          </div>
          <%= form.hidden_field :category_name,
                                value: editing_category,
                                id: "editHabitCategory",
                                data: { dashboard_target: "editCategoryInput" } %>
        </div>

        <div class="dashboard-modal-form__actions">
          <button type="button" class="btn btn-ghost btn-md dashboard-modal-form__button" data-action="dashboard#closeEditModal">Cancel</button>
          <%= form.submit "Update Mission", class: "btn btn-primary btn-md dashboard-modal-form__button" %>
        </div>
      <% end %>
    </div>
  </div>

  <div id="deleteHabitModal"
       class="modal-overlay dashboard-mission-modal <%= 'active' if @show_delete_habit_modal %>"
       data-dashboard-target="deleteModal"
       data-action="click->dashboard#maybeCloseDeleteModal">
    <div class="modal-box">
      <div class="modal-header">
        <h3 class="modal-title">Delete Mission</h3>
        <%= link_to "&times;".html_safe,
                    dashboard_base_path,
                    class: "modal-close",
                    data: { action: "dashboard#closeDeleteModal" } %>
      </div>

      <div class="dashboard-modal-form">
        <p class="dashboard-widget__empty">Do you want to delete this mission?</p>
        <p class="dashboard-subtitle" data-dashboard-target="deleteMissionName"><%= deleting_habit&.title %></p>

        <div class="dashboard-modal-form__actions">
          <%= link_to "Cancel",
                      dashboard_base_path,
                      class: "btn btn-ghost btn-md dashboard-modal-form__button delete-modal-cancel",
                      data: { action: "dashboard#closeDeleteModal" } %>

          <%= form_with url: (deleting_habit.present? ? habit_path(deleting_habit) : "#"),
                        method: :delete,
                        class: "dashboard-modal-form__button",
                        data: { dashboard_target: "deleteForm" } do %>
            <%= submit_tag "Confirm", class: "btn btn-primary btn-md dashboard-modal-form__button" %>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</section>
