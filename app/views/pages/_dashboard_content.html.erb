<%
  total_xp = current_user.total_xp || 0
  level = current_user.level || 1
  next_level_xp = [level * 100, 100].max
  progress_percent = [[current_user.xp_progress_percentage, 0].max, 100].min
  active_habits = @habits.count
  daily_habits = @habits.select { |habit| habit.frequency == "daily" }
  weekly_habits = @habits.select { |habit| habit.frequency == "weekly" }
  completed_today = @habits.count { |habit| habit.habit_logs.any? { |log| log.date == @today && log.completed? } }
  weekly_completed = @weekly_completed_logs.count
  weekly_completion_rate = active_habits.positive? ? [(weekly_completed.to_f / (active_habits * 7) * 100).round, 100].min : 0
  xp_this_week = weekly_completed * 10
  active_category = @current_category.presence || "all"
  dashboard_base_path = dashboard_path({ category: @current_category.presence }.compact)

  category_icon_for = lambda do |category|
    {
      "health" => "❤️",
      "productivity" => "⚡",
      "learning" => "📚",
      "fitness" => "💪",
      "nutrition" => "🥗"
    }[category] || "🎯"
  end

  streak_for = lambda do |habit|
    dates = habit.habit_logs.select(&:completed?).map(&:date).compact.sort.reverse
    next 0 if dates.empty?

    streak = 1
    dates.each_cons(2) do |current_date, previous_date|
      break unless current_date == previous_date + 1.day
      streak += 1
    end
    streak
  end

  best_streak = @habits.map { |habit| streak_for.call(habit) }.max || 0
  login_streak = current_user.login_streak || 0
  editing_habit = @editing_habit || current_user.habits.new
  deleting_habit = @deleting_habit
  editing_category = if editing_habit.respond_to?(:category_name) && editing_habit.category_name.present?
                       editing_habit.category_name
                     elsif editing_habit.respond_to?(:primary_category) && editing_habit.persisted?
                       editing_habit.primary_category
                     else
                       "health"
                     end
%>

<div class="stars-bg" data-controller="stars"></div>

<section class="page-wrapper dashboard-page" data-controller="dashboard">
  <div class="glass-panel neon-glow dashboard-hero">
    <div class="dashboard-hero__halo dashboard-hero__halo--cyan"></div>
    <div class="dashboard-hero__halo dashboard-hero__halo--purple"></div>

    <div class="dashboard-hero__top">
      <div class="dashboard-hero__main">
        <div class="profile-avatar-wrap">
          <div class="avatar">👨‍🚀</div>
          <div class="avatar-badge">✓</div>
        </div>

        <div class="dashboard-hero__copy">
          <h1 class="dashboard-title brand-font">Welcome Back, Commander</h1>
          <p class="dashboard-subtitle">
            Day <%= [login_streak, 1].max %> of your exploration mission
          </p>
          <div class="dashboard-meta">
            <span class="level-badge">LEVEL <%= level %></span>
            <span class="dashboard-meta__xp"><%= total_xp %> XP</span>
          </div>
        </div>
      </div>

      <div class="dashboard-hero__action">
        <button type="button" class="btn btn-primary btn-md dashboard-cta" data-action="dashboard#openCreateModal">
          <span>+</span>
          <span>New Mission</span>
        </button>
      </div>
    </div>

    <div class="xp-panel">
      <div class="dashboard-progress">
        <span class="xp-panel__label">Progress to Level <%= level + 1 %></span>
        <span class="xp-panel__value"><%= total_xp %> / <%= next_level_xp %> XP</span>
      </div>
      <div class="xp-bar">
        <div class="xp-fill" style="width: <%= progress_percent %>%"></div>
      </div>
    </div>

    <div class="dashboard-overview">
      <div class="dashboard-overview__card">
        <span class="dashboard-overview__icon streak-flame">🔥</span>
        <span class="dashboard-overview__value"><%= login_streak %>d</span>
        <span class="dashboard-overview__label">Login Streak</span>
      </div>
      <div class="dashboard-overview__card">
        <span class="dashboard-overview__icon">🏆</span>
        <span class="dashboard-overview__value"><%= current_user.badges.count %></span>
        <span class="dashboard-overview__label">Badges Unlocked</span>
      </div>
      <div class="dashboard-overview__card">
        <span class="dashboard-overview__icon">✅</span>
        <span class="dashboard-overview__value"><%= completed_today %>/<%= active_habits %></span>
        <span class="dashboard-overview__label">Completed Today</span>
      </div>
    </div>
  </div>

  <div class="dashboard-grid">
    <div class="dashboard-main">
      <div class="missions-header">
        <div>
          <h2 class="dashboard-section-title">Missions</h2>
          <p class="dashboard-section-subtitle">
            <span class="dashboard-accent"><%= completed_today %>/<%= active_habits %> completed</span>
            today
          </p>
        </div>
        <div class="dashboard-date"><%= @today.strftime("%A, %B %-d, %Y") %></div>
      </div>

      <div class="filter-bar dashboard-filter-bar">
        <%= link_to "All", dashboard_path, class: "filter-btn #{'active' if active_category == 'all'}", data: { dashboard_target: "filterButton", dashboard_filter: "all", action: "dashboard#filter" } %>
        <%= link_to "Health", dashboard_path(category: "health"), class: "filter-btn #{'active' if active_category == 'health'}", data: { dashboard_target: "filterButton", dashboard_filter: "health", action: "dashboard#filter" } %>
        <%= link_to "Productivity", dashboard_path(category: "productivity"), class: "filter-btn #{'active' if active_category == 'productivity'}", data: { dashboard_target: "filterButton", dashboard_filter: "productivity", action: "dashboard#filter" } %>
        <%= link_to "Learning", dashboard_path(category: "learning"), class: "filter-btn #{'active' if active_category == 'learning'}", data: { dashboard_target: "filterButton", dashboard_filter: "learning", action: "dashboard#filter" } %>
        <%= link_to "Fitness", dashboard_path(category: "fitness"), class: "filter-btn #{'active' if active_category == 'fitness'}", data: { dashboard_target: "filterButton", dashboard_filter: "fitness", action: "dashboard#filter" } %>
        <%= link_to "Nutrition", dashboard_path(category: "nutrition"), class: "filter-btn #{'active' if active_category == 'nutrition'}", data: { dashboard_target: "filterButton", dashboard_filter: "nutrition", action: "dashboard#filter" } %>
      </div>

      <div class="missions-list">
        <% if @habits.any? %>
          <% [["Daily Missions", daily_habits], ["Weekly Missions", weekly_habits]].each do |section_title, habits| %>
            <% next if habits.empty? %>
            <section class="dashboard-section-block" data-dashboard-target="section">
              <div class="missions-section-label"><%= section_title %></div>

              <% habits.each do |habit| %>
                <% category = habit.primary_category %>
                <% completed = habit.habit_logs.any? { |log| log.date == @today && log.completed? } %>
                <% streak = streak_for.call(habit) %>

                <article class="habit-card <%= 'completed' if completed %>" data-dashboard-target="card" data-category="<%= category %>">
                  <div class="dashboard-habit">
                    <div class="dashboard-habit__main">
                      <div class="cat-icon <%= category %>"><%= category_icon_for.call(category) %></div>

                      <div class="dashboard-habit__content">
                        <div class="dashboard-habit__topline">
                          <h3 class="dashboard-habit__title <%= 'is-complete' if completed %>"><%= habit.title %></h3>
                          <span class="category-tag cat-<%= category %>"><%= category %></span>
                        </div>

                        <p class="dashboard-habit__description">
                          <%= habit.description.presence || "Stay consistent and complete this mission to earn XP." %>
                        </p>

                        <div class="dashboard-habit__meta">
                          <span class="streak-flame">🔥 <%= streak %> day<%= "s" if streak != 1 %></span>
                          <span class="dashboard-habit__xp">+10 XP</span>
                        </div>
                      </div>
                    </div>

                    <div class="dashboard-habit__action">
                      <div class="dashboard-habit__controls">
                        <button type="button"
                                class="habit-action-btn"
                                title="Edit"
                                data-action="dashboard#openEditModal"
                                data-habit-id="<%= habit.id %>"
                                data-habit-path="<%= habit_path(habit) %>"
                                data-habit-title="<%= habit.title %>"
                                data-habit-description="<%= habit.description.to_s %>"
                                data-habit-frequency="<%= habit.frequency %>"
                                data-habit-category="<%= category %>">✏️</button>
                        <%= link_to dashboard_path({ category: @current_category.presence, delete_mission_id: habit.id }.compact),
                                    class: "habit-action-btn delete",
                                    title: "Delete",
                                    data: { action: "dashboard#openDeleteModal", habit_delete_path: habit_path(habit), habit_title: habit.title } do %>
                          &times;
                        <% end %>
                      </div>

                      <% if completed %>
                        <button class="mission-success-btn active" disabled>✓ Completed</button>
                      <% else %>
                        <%= button_to "🚀 Mission Success",
                                      habit_habit_logs_path(habit),
                                      method: :post,
                                      params: { habit_log: { date: @today, completed: true, habit_id: habit.id } },
                                      class: "mission-success-btn" %>
                      <% end %>
                    </div>
                  </div>
                </article>
              <% end %>
            </section>
          <% end %>
        <% else %>
          <div class="glass-panel dashboard-empty">
            <h3 class="dashboard-empty__title">No missions yet</h3>
            <p class="dashboard-empty__copy">
              Create your first habit to start earning XP, building streaks, and unlocking badges.
            </p>
            <button type="button" class="btn btn-primary btn-md" data-action="dashboard#openCreateModal">Create First Mission</button>
          </div>
        <% end %>
      </div>
    </div>

    <aside class="sidebar">
      <div class="glass-panel streak-card">
        <div class="streak-card__glow"></div>
        <div class="streak-flame dashboard-sidebar-icon">🔥</div>
        <div class="streak-card__days"><%= login_streak %> Day<%= "s" if login_streak != 1 %></div>
        <div class="streak-card__label">Current Login Streak</div>
        <div class="streak-card__best">Best mission streak: <%= best_streak %> day<%= "s" if best_streak != 1 %></div>
      </div>

      <div class="glass-panel dashboard-widget">
        <h3 class="dashboard-widget__title">🏅 Recent Badges</h3>
        <div class="dashboard-badges">
          <% if @recent_badges.any? %>
            <% @recent_badges.each do |badge| %>
              <div class="badge-item">
                <div class="badge-asset">
                  <% if badge.image_key.present? %>
                    <%= image_tag badge_image(badge),
                                  class: "pixel-badge",
                                  alt: badge.name,
                                  width: 64,
                                  height: 64,
                                  loading: "lazy",
                                  decoding: "async" %>
                  <% else %>
                    <div class="dashboard-badge-fallback"><%= badge.name.first.upcase %></div>
                  <% end %>
                </div>
                <div class="badge-name"><%= badge.name %></div>
              </div>
            <% end %>
          <% else %>
            <p class="dashboard-widget__empty">Your first badges will appear here.</p>
          <% end %>
        </div>
        <%= link_to "View all badges →", statistics_path, class: "dashboard-widget__link", data: { turbo_frame: "_top" } %>
      </div>

      <div class="glass-panel dashboard-widget">
        <h3 class="dashboard-widget__title">📊 This Week</h3>
        <div class="dashboard-stats">
          <div class="dashboard-stat-row">
            <span>Completion Rate</span>
            <strong><%= weekly_completion_rate %>%</strong>
          </div>
          <div class="xp-bar thin">
            <div class="xp-fill green" style="width: <%= weekly_completion_rate %>%"></div>
          </div>
          <div class="dashboard-stat-row">
            <span>Active Habits</span>
            <strong><%= active_habits %></strong>
          </div>
          <div class="dashboard-stat-row">
            <span>XP Earned</span>
            <strong class="dashboard-accent">+<%= xp_this_week %> XP</strong>
          </div>
        </div>
      </div>
    </aside>
  </div>

  <div id="createHabitModal"
       class="modal-overlay dashboard-mission-modal <%= 'active' if @show_create_habit_modal %>"
       data-dashboard-target="createModal"
       data-action="click->dashboard#maybeCloseCreateModal">
    <div class="modal-box">
      <div class="modal-header">
        <h3 class="modal-title">🚀 New Mission</h3>
        <button type="button" class="modal-close" data-action="dashboard#closeCreateModal">&times;</button>
      </div>

      <%= form_with(model: @habit, url: habits_path, class: "dashboard-modal-form") do |form| %>
        <% if @habit.errors.any? %>
          <div class="auth-error">
            <h2 class="auth-error__title"><%= pluralize(@habit.errors.count, "error") %> prevented this mission from being saved:</h2>
            <ul>
              <% @habit.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div class="form-group">
          <%= form.label :title, "Mission Name", class: "form-label" %>
          <%= form.text_field :title,
                              class: "input",
                              placeholder: "e.g., Morning Meditation",
                              required: true %>
        </div>

        <div class="form-group">
          <%= form.label :description, "Description", class: "form-label" %>
          <%= form.text_area :description,
                             rows: 3,
                             class: "textarea",
                             placeholder: "Describe your goal..." %>
        </div>

        <div class="form-group">
          <label class="form-label">Frequency</label>
          <div class="dashboard-modal-form__choices">
            <button type="button"
                    class="freq-option <%= (@habit.frequency || 'daily') == 'daily' ? 'selected' : '' %>"
                    data-action="dashboard#selectCreateFrequency"
                    data-frequency-option
                    data-value="daily">
              <span class="freq-icon">📅</span>
              <span class="freq-title">Daily</span>
              <span class="freq-desc">Validate every day</span>
            </button>
            <button type="button"
                    class="freq-option <%= @habit.frequency == 'weekly' ? 'selected' : '' %>"
                    data-action="dashboard#selectCreateFrequency"
                    data-frequency-option
                    data-value="weekly">
              <span class="freq-icon">📆</span>
              <span class="freq-title">Weekly</span>
              <span class="freq-desc">Once per week only</span>
            </button>
          </div>
          <%= form.hidden_field :frequency,
                                value: (@habit.frequency || "daily"),
                                data: { dashboard_target: "createFrequencyInput" } %>
        </div>

        <div class="form-group">
          <label class="form-label">Category (select one)</label>
          <% selected_category = @habit.category_name.presence || "health" %>
          <div class="dashboard-modal-form__tags">
            <button type="button" class="selectable-tag tag-health <%= 'selected' if selected_category == 'health' %>" data-action="dashboard#selectCreateCategory" data-category-option data-value="health">❤️ Health</button>
            <button type="button" class="selectable-tag tag-productivity <%= 'selected' if selected_category == 'productivity' %>" data-action="dashboard#selectCreateCategory" data-category-option data-value="productivity">⚡ Productivity</button>
            <button type="button" class="selectable-tag tag-learning <%= 'selected' if selected_category == 'learning' %>" data-action="dashboard#selectCreateCategory" data-category-option data-value="learning">📚 Learning</button>
            <button type="button" class="selectable-tag tag-fitness <%= 'selected' if selected_category == 'fitness' %>" data-action="dashboard#selectCreateCategory" data-category-option data-value="fitness">💪 Fitness</button>
            <button type="button" class="selectable-tag tag-nutrition <%= 'selected' if selected_category == 'nutrition' %>" data-action="dashboard#selectCreateCategory" data-category-option data-value="nutrition">🥗 Nutrition</button>
          </div>
          <%= form.hidden_field :category_name,
                                value: selected_category,
                                data: { dashboard_target: "createCategoryInput" } %>
        </div>

        <div class="dashboard-modal-form__actions">
          <button type="button" class="btn btn-ghost btn-md dashboard-modal-form__button" data-action="dashboard#closeCreateModal">Cancel</button>
          <%= form.submit "Create Mission", class: "btn btn-primary btn-md dashboard-modal-form__button" %>
        </div>
      <% end %>
    </div>
  </div>

  <div id="editHabitModal"
       class="modal-overlay dashboard-mission-modal <%= 'active' if @show_edit_habit_modal %>"
       data-dashboard-target="editModal"
       data-action="click->dashboard#maybeCloseEditModal">
    <div class="modal-box">
      <div class="modal-header">
        <h3 class="modal-title">✏️ Edit Mission</h3>
        <button type="button" class="modal-close" data-action="dashboard#closeEditModal">&times;</button>
      </div>

      <%= form_with(scope: :habit,
                    url: (@editing_habit&.persisted? ? habit_path(@editing_habit) : "#"),
                    method: :post,
                    html: { class: "dashboard-modal-form", id: "editHabitForm", data: { dashboard_target: "editForm" } }) do |form| %>
        <%= hidden_field_tag :_method, "patch", id: "editHabitMethod" %>

        <% if @editing_habit&.errors&.any? %>
          <div class="auth-error">
            <h2 class="auth-error__title"><%= pluralize(@editing_habit.errors.count, "error") %> prevented this mission from being updated:</h2>
            <ul>
              <% @editing_habit.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div class="form-group">
          <%= form.label :title, "Mission Name", class: "form-label" %>
          <%= form.text_field :title,
                              class: "input",
                              placeholder: "e.g., Morning Meditation",
                              required: true,
                              id: "editHabitTitle",
                              value: editing_habit.title,
                              data: { dashboard_target: "editTitle" } %>
        </div>

        <div class="form-group">
          <%= form.label :description, "Description", class: "form-label" %>
          <%= form.text_area :description,
                             rows: 3,
                             class: "textarea",
                             placeholder: "Describe your goal...",
                             id: "editHabitDescription",
                             data: { dashboard_target: "editDescription" } do %><%= editing_habit.description %><% end %>
        </div>

        <div class="form-group">
          <label class="form-label">Frequency</label>
          <div class="dashboard-modal-form__choices">
            <button type="button"
                    class="freq-option <%= (editing_habit.frequency || 'daily') == 'daily' ? 'selected' : '' %>"
                    data-action="dashboard#selectEditFrequency"
                    data-edit-frequency-option
                    data-value="daily">
              <span class="freq-icon">📅</span>
              <span class="freq-title">Daily</span>
              <span class="freq-desc">Validate every day</span>
            </button>
            <button type="button"
                    class="freq-option <%= editing_habit.frequency == 'weekly' ? 'selected' : '' %>"
                    data-action="dashboard#selectEditFrequency"
                    data-edit-frequency-option
                    data-value="weekly">
              <span class="freq-icon">📆</span>
              <span class="freq-title">Weekly</span>
              <span class="freq-desc">Once per week only</span>
            </button>
          </div>
          <%= form.hidden_field :frequency,
                                value: (editing_habit.frequency || "daily"),
                                id: "editHabitFrequency",
                                data: { dashboard_target: "editFrequencyInput" } %>
        </div>

        <div class="form-group">
          <label class="form-label">Category (select one)</label>
          <div class="dashboard-modal-form__tags">
            <button type="button" class="selectable-tag tag-health <%= 'selected' if editing_category == 'health' %>" data-action="dashboard#selectEditCategory" data-edit-category-option data-value="health">❤️ Health</button>
            <button type="button" class="selectable-tag tag-productivity <%= 'selected' if editing_category == 'productivity' %>" data-action="dashboard#selectEditCategory" data-edit-category-option data-value="productivity">⚡ Productivity</button>
            <button type="button" class="selectable-tag tag-learning <%= 'selected' if editing_category == 'learning' %>" data-action="dashboard#selectEditCategory" data-edit-category-option data-value="learning">📚 Learning</button>
            <button type="button" class="selectable-tag tag-fitness <%= 'selected' if editing_category == 'fitness' %>" data-action="dashboard#selectEditCategory" data-edit-category-option data-value="fitness">💪 Fitness</button>
            <button type="button" class="selectable-tag tag-nutrition <%= 'selected' if editing_category == 'nutrition' %>" data-action="dashboard#selectEditCategory" data-edit-category-option data-value="nutrition">🥗 Nutrition</button>
          </div>
          <%= form.hidden_field :category_name,
                                value: editing_category,
                                id: "editHabitCategory",
                                data: { dashboard_target: "editCategoryInput" } %>
        </div>

        <div class="dashboard-modal-form__actions">
          <button type="button" class="btn btn-ghost btn-md dashboard-modal-form__button" data-action="dashboard#closeEditModal">Cancel</button>
          <%= form.submit "Update Mission", class: "btn btn-primary btn-md dashboard-modal-form__button" %>
        </div>
      <% end %>
    </div>
  </div>

  <div id="deleteHabitModal"
       class="modal-overlay dashboard-mission-modal <%= 'active' if @show_delete_habit_modal %>"
       data-dashboard-target="deleteModal"
       data-action="click->dashboard#maybeCloseDeleteModal">
    <div class="modal-box">
      <div class="modal-header">
        <h3 class="modal-title">Delete Mission</h3>
        <%= link_to "&times;".html_safe,
                    dashboard_base_path,
                    class: "modal-close",
                    data: { action: "dashboard#closeDeleteModal" } %>
      </div>

      <div class="dashboard-modal-form">
        <p class="dashboard-widget__empty">Do you want to delete this mission?</p>
        <p class="dashboard-subtitle" data-dashboard-target="deleteMissionName"><%= deleting_habit&.title %></p>

        <div class="dashboard-modal-form__actions">
          <%= link_to "Cancel",
                      dashboard_base_path,
                      class: "btn btn-ghost btn-md dashboard-modal-form__button delete-modal-cancel",
                      data: { action: "dashboard#closeDeleteModal" } %>

          <%= form_with url: (deleting_habit.present? ? habit_path(deleting_habit) : "#"),
                        method: :delete,
                        class: "dashboard-modal-form__button",
                        data: { dashboard_target: "deleteForm" } do %>
            <%= submit_tag "Confirm", class: "btn btn-primary btn-md dashboard-modal-form__button" %>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</section>
